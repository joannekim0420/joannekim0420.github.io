/* ============================================================
   detail.js — Renders a detail page for /career/{slug}/ and /papers/{slug}/
   Reads slug from URL, fetches /data/{section}.json (array), finds item by slug, renders.
   ============================================================ */
(function () {
  'use strict';

  function escapeHTML(s) {
    if (s == null) return '';
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  function bi(kr, en) {
    return (
      '<span class="kr-only">' + escapeHTML(kr || en || '') + '</span>' +
      '<span class="en-only">' + escapeHTML(en || kr || '') + '</span>'
    );
  }

  /* Parse path: /career/sangmyung/  -> { section: 'career', slug: 'sangmyung' } */
  function parsePath() {
    const path = window.location.pathname.replace(/\/$/, '');
    const parts = path.split('/').filter(Boolean);
    if (parts.length < 2) return null;
    return {
      section: parts[parts.length - 2], // 'career' or 'papers'
      slug: parts[parts.length - 1],
    };
  }

  /* Render bullet list (accepts array of strings) */
  function renderList(items) {
    if (!items || !items.length) return '';
    return '<ul>' + items.map((s) => '<li>' + escapeHTML(s) + '</li>').join('') + '</ul>';
  }

  /* Render a single bilingual block: { kr: [...], en: [...] } */
  function biList(obj) {
    if (!obj) return '';
    return (
      '<div class="kr-only">' + renderList(obj.kr) + '</div>' +
      '<div class="en-only">' + renderList(obj.en) + '</div>'
    );
  }

  /* Render a figure (image with caption) */
  function fig(image) {
    if (!image || !image.src) return '';
    return (
      '<figure class="detail-figure">' +
      '<img src="' + escapeHTML(image.src) + '" alt="' + escapeHTML(image.alt || '') + '">' +
      (image.caption_kr || image.caption_en
        ? '<figcaption>' + bi(image.caption_kr, image.caption_en) + '</figcaption>'
        : '') +
      '</figure>'
    );
  }

  /* ---------- Section renderers ---------- */
  function renderCareer(item) {
    let html = '';
    if (item.hero_img) {
      html += '<div class="detail-hero-img"><img src="' + escapeHTML(item.hero_img) + '" alt=""></div>';
    }
    html += '<h1 class="detail-title">' + bi(item.title_kr, item.title_en) + '</h1>';
    html += '<p class="detail-meta">' + bi(item.subtitle_kr, item.subtitle_en) + '</p>';
    if (item.tags && item.tags.length) {
      html += '<div class="tag-row">';
      item.tags.forEach(function (t) {
        html += '<span class="tag">' + escapeHTML(t) + '</span>';
      });
      html += '</div>';
    }

    /* sections: array of { heading_kr, heading_en, body: { kr, en }, image } */
    if (item.sections) {
      item.sections.forEach(function (s) {
        html += '<div class="detail-section">';
        html += '<h2>' + bi(s.heading_kr, s.heading_en) + '</h2>';
        if (s.body) html += biList(s.body);
        if (s.image) html += fig(s.image);
        html += '</div>';
      });
    }
    return html;
  }

  function renderPaper(item) {
    let html = '';
    if (item.hero_img) {
      html += '<div class="detail-hero-img"><img src="' + escapeHTML(item.hero_img) + '" alt=""></div>';
    }
    html += '<h1 class="detail-title">' + bi(item.title_kr, item.title_en) + '</h1>';
    html +=
      '<p class="detail-meta">' +
      escapeHTML(item.venue || '') +
      (item.year ? ' · ' + escapeHTML(item.year) : '') +
      '</p>';
    if (item.tags && item.tags.length) {
      html += '<div class="tag-row">';
      item.tags.forEach(function (t) {
        html += '<span class="tag">' + escapeHTML(t) + '</span>';
      });
      html += '</div>';
    }

    if (item.sections) {
      item.sections.forEach(function (s) {
        html += '<div class="detail-section">';
        html += '<h2>' + bi(s.heading_kr, s.heading_en) + '</h2>';
        if (s.body) html += biList(s.body);
        if (s.image) html += fig(s.image);
        html += '</div>';
      });
    }

    if (item.links && item.links.length) {
      html += '<div class="detail-section"><h2>' + bi('관련 링크', 'Links') + '</h2><ul>';
      item.links.forEach(function (l) {
        html += '<li><a href="' + escapeHTML(l.url) + '" target="_blank" rel="noopener">' + escapeHTML(l.label) + '</a></li>';
      });
      html += '</ul></div>';
    }

    return html;
  }

  /* ---------- Boot ---------- */
  async function boot() {
    const root = document.getElementById('detail-root');
    if (!root) return;
    const parsed = parsePath();
    if (!parsed) {
      root.innerHTML = '<p class="empty">Invalid URL.</p>';
      return;
    }
    const fileMap = { career: 'career-detail.json', papers: 'papers.json' };
    const file = fileMap[parsed.section];
    if (!file) {
      root.innerHTML = '<p class="empty">Unknown section.</p>';
      return;
    }
    try {
      const res = await fetch('/data/' + file);
      if (!res.ok) throw new Error('HTTP ' + res.status);
      const arr = await res.json();
      const item = (arr || []).find(function (x) {
        return x.slug === parsed.slug;
      });
      if (!item) {
        root.innerHTML = '<p class="empty">Item not found.</p>';
        return;
      }
      document.title =
        (item.title_kr || item.title_en || parsed.slug) + ' · Joanne Kim';
      root.innerHTML =
        parsed.section === 'career' ? renderCareer(item) : renderPaper(item);
    } catch (e) {
      console.error('[detail.js]', e);
      root.innerHTML = '<p class="empty">Failed to load. Please refresh.</p>';
    }
  }

  document.addEventListener('DOMContentLoaded', boot);
})();
