/* ============================================================
   i18n.js — Language toggle (KR / EN) with localStorage persistence
   Default language: KR
   ============================================================ */
(function () {
  'use strict';

  const STORAGE_KEY = 'jk-lang';
  const DEFAULT_LANG = 'kr';

  function getInitialLang() {
    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved === 'kr' || saved === 'en') return saved;
    } catch (e) {
      /* localStorage may be unavailable */
    }
    return DEFAULT_LANG;
  }

  function applyLang(lang) {
    document.body.classList.remove('lang-kr', 'lang-en');
    document.body.classList.add('lang-' + lang);
    try { localStorage.setItem(STORAGE_KEY, lang); } catch (e) {}
    document.querySelectorAll('.lang-toggle button').forEach(function (btn) {
      btn.classList.toggle('active', btn.dataset.lang === lang);
    });
  }

  /* Apply ASAP so flash of wrong language is minimized */
  const initial = getInitialLang();
  if (document.body) {
    document.body.classList.add('lang-' + initial);
  } else {
    document.addEventListener('DOMContentLoaded', function () {
      document.body.classList.add('lang-' + initial);
    });
  }

  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.lang-toggle button').forEach(function (btn) {
      btn.classList.toggle('active', btn.dataset.lang === initial);
      btn.addEventListener('click', function () {
        applyLang(btn.dataset.lang);
      });
    });
  });
})();
